# ระบุชื่อตัวแปรที่ใช้ใน compose.yaml เพื่อให้สอดคล้องกับการใช้งานในไฟล์นั้น
PROJECT_NAME=my_lab_db

MY_USERNAME=root #ใส่ชื่อผู้ใช้ของคุณ
# พอร์ตที่ใช้สำหรับบริการต่าง ๆ

# พอร์ตสำหรับ Web Proxy (Nginx): 10000 + (20 * 100) + 1
HTTP_PORT=12001
# พอร์ตสำหรับ phpMyAdmin: 10000 + (20 * 100) + 2
PMA_PORT=12002

# DB Details
DB_USER=root
DB_PASSWORD=ad_123
HTTP_PORT=8080

